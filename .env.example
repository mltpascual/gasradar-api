# GasRadar API Environment Variables
# Copy this to .env and fill in your values

# Database (Railway provides this automatically)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/gasradar

# Admin API Key (change this in production!)
ADMIN_API_KEY=gasradar_admin_change_me_in_production

# CORS Origins (comma-separated)
CORS_ORIGINS=*

# Rate Limiting Storage ("memory" for MVP, "redis://..." for production)
RATE_LIMIT_STORAGE=memory

# Logging Level
LOG_LEVEL=INFO

# Debug Mode
DEBUG=false
